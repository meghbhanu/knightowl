FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    gcc \
    wget \
    unzip \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

RUN mkdir -p /app/engines \
    && wget -q https://github.com/official-stockfish/Stockfish/releases/download/sf_16/stockfish-ubuntu-x86-64-avx2.tar \
    && tar -xf stockfish-ubuntu-x86-64-avx2.tar \
    && if [ -f stockfish/stockfish-ubuntu-x86-64-avx2 ]; then mv stockfish/stockfish-ubuntu-x86-64-avx2 /app/engines/stockfish; \
    elif [ -f stockfish-ubuntu-x86-64-avx2 ]; then mv stockfish-ubuntu-x86-64-avx2 /app/engines/stockfish; \
    else echo 'Stockfish binary not found in archive' && exit 1; fi \
    && chmod +x /app/engines/stockfish \
    && rm -rf stockfish stockfish-ubuntu-x86-64-avx2.tar

COPY . .

EXPOSE 8000

COPY start.sh .
RUN chmod +x start.sh
CMD ["./start.sh"]
